generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  headline        String?
  designation     String?
  company         String?
  location        String?
  city            String?
  email           String?
  phone           String?
  linkedin_url    String   @unique
  profile_image   String?
  bio             String?
  connectionCount String?
  skills          String   @default("[]") // Store as JSON string array
  saved_at        DateTime @default(now())
  notes           String?
  tags            String   @default("[]") // Store as JSON string array
  status          String   @default("NEW") // Built-in statuses: NEW, CONTACTED, QUALIFIED, REJECTED
}
