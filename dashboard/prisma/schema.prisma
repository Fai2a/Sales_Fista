generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  designation     String?
  company         String?
  location        String?
  email           String?
  phone           String?
  profileUrl      String?
  photoUrl        String?
  bio             String?
  connectionCount String?
  savedAt         DateTime @default(now())
  notes           String?
  tags            String   @default("[]") // Store as JSON string array
  status          String   @default("NEW") // Built-in statuses: NEW, CONTACTED, QUALIFIED, REJECTED
}
