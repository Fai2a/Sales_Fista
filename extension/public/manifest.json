{
  "manifest_version": 3,
  "name": "LinkedIn Profile Scraper",
  "version": "1.0.0",
  "description": "Scrape LinkedIn profile data and save it directly to the Next.js Dashboard.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/in/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["src/content.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
